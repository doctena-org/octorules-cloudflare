#!/usr/bin/env bash
# Pre-commit hook: regenerate schemas.json when overlay.toml or the
# wirefilter dependency version changes. Keeps the frozen fallback in
# sync without manual intervention.
#
# Install: from the repo root, run:
#   ln -sf ../../scripts/hooks/pre-commit .git/hooks/pre-commit
set -euo pipefail

# Only act when relevant files are staged
if ! git diff --cached --name-only | grep -qE '(overlay\.toml|pyproject\.toml)'; then
    exit 0
fi

# Skip if wirefilter is not installed (can't regenerate)
if ! python -c "import octorules_wirefilter" 2>/dev/null; then
    exit 0
fi

echo "pre-commit: regenerating schemas.json (overlay.toml or pyproject.toml changed)"
python scripts/sync_schemas.py
git add octorules_cloudflare/linter/schemas/schemas.json
